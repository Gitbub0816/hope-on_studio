{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@engine/*": ["site/src/engine/*"],
      "@motion/*": ["site/src/motion/*"],
      "@blocks/*": ["site/src/blocks/*"],
      "@styles/*": ["site/src/styles/*"]
    }
  },
  "include": ["site/src", "shared", "admin/src"],
  "exclude": ["node_modules", "dist", "worker"]
}
